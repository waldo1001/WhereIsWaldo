<?xml version="1.0" encoding="utf-8"?>
<!--
  Security (docs/security-review-checklist.md §5): the default, TLS-only config with NO
  cleartext exemption — this is what the release build type uses (release has no res/xml
  override, so it falls back to this main one). The debug-only 10.0.2.2 emulator-loopback
  carve-out lives exclusively in `app/src/debug/res/xml/network_security_config.xml`, which
  Android's build-variant resource merging uses INSTEAD of this file for debug builds only, so
  it can never compile into a release APK.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
